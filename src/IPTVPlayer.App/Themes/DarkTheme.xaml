<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:conv="clr-namespace:IPTVPlayer.App.Converters">
    <Color x:Key="BackgroundColor">#121722</Color>
    <Color x:Key="PanelColor">#1B2232</Color>
    <Color x:Key="AccentColor">#30C6F2</Color>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />
    <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource PanelColor}" />
    <SolidColorBrush x:Key="ForegroundBrush" Color="#E7EDF8" />

    <conv:BooleanToVisibilityConverter x:Key="BoolToVisibility" />

    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource BackgroundBrush}" />
        <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
    </Style>

    <Style x:Key="PanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource PanelBrush}" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="4" />
    </Style>

    <Style TargetType="Button">
        <Setter Property="Background" Value="#233047" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderBrush" Value="#2B3D5D" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="Margin" Value="4" />
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Background" Value="#24314A" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderBrush" Value="#3D4D6A" />
    </Style>

    <Style TargetType="ListBox">
        <Setter Property="Background" Value="#202B41" />
        <Setter Property="BorderBrush" Value="#3B4B68" />
        <Setter Property="Foreground" Value="White" />
    </Style>
</ResourceDictionary>
